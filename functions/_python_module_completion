#compdef python python3

_python_module_completion() {
    # Check if we should use local completion first
    if ! _should_use_local_completion; then
        # Fall back to zsh's default python completion
        _python_original_wrapper "$@"
        return $?
    fi
    
    # Check if -m option is in the command line (including current word)
    local has_m_option=0
    local i
    for ((i=1; i <= CURRENT; i++)); do
        if [[ "${words[i]}" == "-m" ]]; then
            has_m_option=1
            break
        fi
    done
    
    # Also check if current word starts with -m (for cases like -m<TAB>)
    if [[ "${words[CURRENT]}" == -m* ]]; then
        has_m_option=1
    fi
    
    # If no -m option at or before current position, use default completion
    if [[ $has_m_option -eq 0 ]]; then
        _python_original_wrapper "$@"
        return $?
    fi
    
    # Use our custom completion for -m module completion
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '-m[run library module as a script]:module:->module' \
        '*::arg:->args' && return 0

    case "$state" in
        module)
            # Now we're completing the module after -m
            _python_complete_modules
            return 0
            ;;
        *)
            # For other states, fall back to default completion
            _python_original_wrapper "$@"
            return $?
            ;;
    esac
}

# Wrapper function to call the original Python completion
_python_original_wrapper() {
    if [[ -n "$_PYTHON_ORIGINAL_COMPLETION" ]]; then
        # Execute the original completion function body in current context
        eval "$_PYTHON_ORIGINAL_COMPLETION"
    else
        # Fallback if original wasn't saved (shouldn't happen)
        autoload +X _python 2>/dev/null
        _python "$@"
        return $?
    fi
}

_python_complete_modules() {
    # We've already checked _should_use_local_completion in the main function.
    # Complete using full module paths and optionally let fzf pick one.
    local -a modules candidates
    local cur_word selected

    modules=($(_find_python_modules))
    cur_word="${words[CURRENT]}"

    for module in "${modules[@]}"; do
        if [[ -z "$cur_word" || "$module" == "$cur_word"* ]]; then
            candidates+=("$module")
        fi
    done

    if [[ ${#candidates[@]} -eq 0 ]]; then
        return 0
    fi

    selected=$(_python_select_with_fzf "${candidates[@]}")
    if [[ -n "$selected" ]]; then
        # Replace current word with the selected full module path.
        compadd -Q -S " " -- "$selected"
        return 0
    fi

    compadd -Q -a candidates
}

_python_select_with_fzf() {
    local -a options
    local selected
    options=("$@")

    if (( ${#options[@]} == 0 )); then
        return 0
    fi

    # Only use fzf when available in an interactive shell.
    if ! command -v fzf >/dev/null 2>&1 || [[ ! -o interactive ]]; then
        return 0
    fi

    selected=$(printf '%s\n' "${options[@]}" | fzf \
        --prompt='python -m > ' \
        --height=40% \
        --layout=reverse \
        --border \
        --select-1 \
        --exit-0 \
        --query="$PREFIX")

    if [[ -n "$selected" ]]; then
        printf '%s' "$selected"
    fi
}

_is_python_project() {
    # Check for common virtual environment directory names
    if [ -d "venv" ] || [ -d ".venv" ] || [ -d "env" ] || [ -d ".env" ]; then
        return 0
    fi

    # Check for directories with pyvenv.cfg (virtual environment marker)
    if [ -n "$(find . -maxdepth 2 -name "pyvenv.cfg" -print -quit 2>/dev/null)" ]; then
        return 0
    fi

    # Check if current Python is in a virtual environment
    local python_path
    python_path=$(python -c "import sys; print(sys.executable)" 2>/dev/null)
    if [[ -n "$python_path" && "$python_path" == *"/venv/"* ]] || \
       [[ -n "$python_path" && "$python_path" == *"/.venv/"* ]] || \
       [[ -n "$python_path" && "$python_path" == *"/env/"* ]] || \
       [[ -n "$python_path" && "$python_path" == *"/.env/"* ]]; then
        return 0
    fi

    # Also check python3 if python is not available or doesn't indicate a venv
    python_path=$(python3 -c "import sys; print(sys.executable)" 2>/dev/null)
    if [[ -n "$python_path" && "$python_path" == *"/venv/"* ]] || \
       [[ -n "$python_path" && "$python_path" == *"/.venv/"* ]] || \
       [[ -n "$python_path" && "$python_path" == *"/env/"* ]] || \
       [[ -n "$python_path" && "$python_path" == *"/.env/"* ]]; then
        return 0
    fi

    # Check for conda environment
    if [[ -n "$CONDA_DEFAULT_ENV" ]] || [[ -n "$VIRTUAL_ENV" ]]; then
        return 0
    fi

    # Check for project files
    if [ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ] || [ -f "Pipfile" ] || [ -f "poetry.lock" ]; then
        return 0
    fi

    # Check for __init__.py files
    if [ -n "$(find . -maxdepth 3 -name '__init__.py' -print -quit)" ]; then
        return 0
    fi

    return 1
}

_should_use_local_completion() {
    # Check if .local_module_completion file exists in current or parent directories
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        if [[ -f "$dir/.local_module_completion" ]]; then
            # Also verify we're in a Python project
            if _is_python_project; then
                return 0
            fi
            return 1
        fi
        dir="${dir:h}"
    done
    return 1
}

_find_python_modules() {
    local exclude_paths modules py_files
    
    # Build exclusion list for virtual environments and common non-project directories
    exclude_paths=""
    
    # Exclude common virtual environment directory names
    for venv_dir in "venv" ".venv" "env" ".env"; do
        if [ -d "$venv_dir" ]; then
            exclude_paths="$exclude_paths -not -path './$venv_dir/*'"
        fi
    done
    
    # Find and exclude directories with pyvenv.cfg
    local -a pyvenv_dirs
    pyvenv_dirs=($(find . -maxdepth 2 -name "pyvenv.cfg" -exec dirname {} \; 2>/dev/null | sed 's|^\./||'))
    for pyvenv_dir in "${pyvenv_dirs[@]}"; do
        if [[ -n "$pyvenv_dir" ]]; then
            exclude_paths="$exclude_paths -not -path './$pyvenv_dir/*'"
        fi
    done
    
    # Also exclude common build/cache directories
    exclude_paths="$exclude_paths -not -path './__pycache__/*' -not -path './build/*' -not -path './dist/*' -not -path './.pytest_cache/*' -not -path './.tox/*' -not -path './node_modules/*'"
    
    # Find packages (directories with __init__.py)
    local package_cmd
    package_cmd="find . -type f -name '__init__.py' $exclude_paths"
    local -a all_init_files
    all_init_files=($(eval $package_cmd | sed -e 's|/__init__\.py$||g' -e 's|^\./||g' | grep -v '^$'))
    
    # Helper function to check if all parent directories have __init__.py
    _has_init_in_all_parents() {
        local module_path="$1"
        # Split by / to get directory components
        local -a parts
        parts=(${(s:/:)module_path})
        
        # Check each level from top to current
        local current=""
        for part in "${parts[@]}"; do
            if [[ -n "$current" ]]; then
                current="$current/$part"
            else
                current="$part"
            fi
            
            # Check if this level has __init__.py
            if [[ ! -f "./$current/__init__.py" ]]; then
                return 1
            fi
        done
        return 0
    }
    
    # Filter to only include modules where all parents have __init__.py
    local -a valid_modules
    for module_path in "${all_init_files[@]}"; do
        if _has_init_in_all_parents "$module_path"; then
            # Convert path to module notation (replace / with .)
            valid_modules+=("${module_path//\//.}")
        fi
    done
    
    # Find top-level Python files (in root directory only)
    py_files=$(find . -maxdepth 1 -type f -name '*.py' -not -name '__init__.py' | sed -e 's|\.py$||g' -e 's|^\./||g' | grep -v '^$')
    
    # Find Python files in valid package directories
    local -a package_py_files_array
    for module_path in "${all_init_files[@]}"; do
        if _has_init_in_all_parents "$module_path"; then
            local dir_path="./$module_path"
            local -a files_in_package
            files_in_package=($(find "$dir_path" -maxdepth 1 -type f -name '*.py' -not -name '__init__.py' 2>/dev/null | sed -e 's|\.py$||g' -e 's|^\./||g' -e 's|/|.|g' | grep -v '^$'))
            package_py_files_array+=("${files_in_package[@]}")
        fi
    done
    
    # Combine and sort packages, top-level files, and package files
    {
        printf '%s\n' "${valid_modules[@]}"
        echo "$py_files"
        printf '%s\n' "${package_py_files_array[@]}"
    } | grep -v '^$' | sort -u
}

